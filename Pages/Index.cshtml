@page
@model IndexModel
@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="text-center py-5">
    <h1 class="display-3 fw-bold text-primary">🚀 BasicNet10</h1>
    <p class="lead text-muted">ASP.NET Core 10 ile oluşturulmuş modern bir web uygulaması</p>
    <hr class="my-4" />
</div>

<div class="row g-4 mt-2">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body text-center p-4">
                <div class="fs-1 mb-3">⚡</div>
                <h5 class="card-title fw-bold">.NET 10</h5>
                <p class="card-text text-muted">Microsoft'un en güncel .NET platformu ile yüksek performanslı uygulama.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body text-center p-4">
                <div class="fs-1 mb-3">📄</div>
                <h5 class="card-title fw-bold">Razor Pages</h5>
                <p class="card-text text-muted">Sayfa tabanlı temiz mimari ile kolay geliştirme deneyimi.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body text-center p-4">
                <div class="fs-1 mb-3">🎨</div>
                <h5 class="card-title fw-bold">Bootstrap 5</h5>
                <p class="card-text text-muted">Mobil uyumlu, modern ve şık kullanıcı arayüzü.</p>
            </div>
        </div>
    </div>
</div>

<div class="text-center mt-5">
    <a href="https://learn.microsoft.com/aspnet/core" target="_blank" class="btn btn-primary btn-lg px-4">
        Belgeleri İncele
    </a>
    <a href="/Privacy" class="btn btn-outline-secondary btn-lg px-4 ms-2">
        Gizlilik Politikası
    </a>
</div>
